{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.bar.json",
  "monitor": {
    "index": 0
  },
  "font_family": "CaskaydiaCove NF",
  "font_size": 12.5,
  "icon_scale": 1.2,
  "height": 38,
  "max_label_width": 200,
  "margin": {
    "horizontal": 0,
    "vertical": 6
  },
  "padding": {
    "horizontal": 14,
    "vertical": 4
  },
  "widget_spacing": 14,
  "transparency_alpha": 0,
  "grouping": {
    "kind": "Alignment",
    "style": "Default",
    "rounding": 12,
    "transparency_alpha": 217
  },
  "theme": {
    "palette": "Base16",
    "name": "RosePine",
    "accent": "Base0E"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "display": "Icon",
          "hide_empty_workspaces": true
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": true
        }
      }
    }
  ],
  "center_widgets": [
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    }
  ],
  "right_widgets": [
    {
      "Date": {
        "enable": true,
        "format": "DayDateMonthYear"
      }
    }
  ]
}
