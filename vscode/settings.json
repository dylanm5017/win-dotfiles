{
    // win-dotfiles VSCode overlay. Deep-merged into %APPDATA%\Code\User\settings.json by
    // `winsmooth -Apply` (machine-specific keys are preserved). The colorCustomizations block
    // between the theme markers is rewritten by the `theme <name>` command from the active
    // palette (themes/<name>.psd1 YasbPalette), so VSCode's chrome tracks the rest of the rice.
    //
    // Syntax highlighting still follows whatever color theme you pick in VSCode; this only
    // recolours the workbench chrome (title bar, activity/side bar, tabs, status bar, panels)
    // to match the palette. titleBarStyle must be "custom" for the title-bar colours to apply.
    "editor.fontFamily": "CaskaydiaCove NF, Cascadia Code, Consolas, monospace",
    "editor.fontLigatures": true,
    "terminal.integrated.fontFamily": "CaskaydiaCove NF",
    "window.titleBarStyle": "custom",

    // win-dotfiles:theme:start
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#191724",
        "titleBar.activeForeground": "#e0def4",
        "titleBar.inactiveBackground": "#191724",
        "titleBar.inactiveForeground": "#908caa",
        "titleBar.border": "#1f1d2e",
        "activityBar.background": "#191724",
        "activityBar.foreground": "#ebbcba",
        "activityBar.inactiveForeground": "#908caa",
        "activityBar.activeBorder": "#ebbcba",
        "activityBarBadge.background": "#ebbcba",
        "activityBarBadge.foreground": "#191724",
        "sideBar.background": "#191724",
        "sideBar.foreground": "#908caa",
        "sideBarTitle.foreground": "#e0def4",
        "sideBarSectionHeader.background": "#1f1d2e",
        "sideBarSectionHeader.foreground": "#e0def4",
        "statusBar.background": "#191724",
        "statusBar.foreground": "#908caa",
        "statusBar.noFolderBackground": "#191724",
        "statusBar.debuggingBackground": "#ebbcba",
        "statusBar.debuggingForeground": "#191724",
        "editor.background": "#191724",
        "editorGroupHeader.tabsBackground": "#191724",
        "tab.activeBackground": "#1f1d2e",
        "tab.inactiveBackground": "#191724",
        "tab.activeForeground": "#e0def4",
        "tab.inactiveForeground": "#908caa",
        "tab.activeBorderTop": "#ebbcba",
        "tab.border": "#191724",
        "panel.background": "#191724",
        "panelTitle.activeForeground": "#e0def4",
        "button.background": "#ebbcba",
        "button.foreground": "#191724",
        "button.hoverBackground": "#c4a7e7",
        "focusBorder": "#ebbcba",
        "list.activeSelectionBackground": "#1f1d2e",
        "list.activeSelectionForeground": "#e0def4",
        "list.hoverBackground": "#1f1d2e",
        "badge.background": "#ebbcba",
        "badge.foreground": "#191724",
        "terminal.background": "#191724",
        "terminal.foreground": "#e0def4"
    }
    // win-dotfiles:theme:end
}
