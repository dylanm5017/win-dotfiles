{
    // win-dotfiles VSCode overlay. Deep-merged into %APPDATA%\Code\User\settings.json by
    // `winsmooth -Apply` (machine-specific keys are preserved). The colorCustomizations block
    // between the theme markers is rewritten by the `theme <name>` command from the active
    // palette (themes/<name>.psd1 YasbPalette), so VSCode's chrome tracks the rest of the rice.
    //
    // Syntax highlighting still follows whatever color theme you pick in VSCode; this only
    // recolours the workbench chrome (title bar, activity/side bar, tabs, status bar, panels)
    // to match the palette. titleBarStyle must be "custom" for the title-bar colours to apply.
    "editor.fontFamily": "CaskaydiaCove NF, Cascadia Code, Consolas, monospace",
    "editor.fontLigatures": true,
    "terminal.integrated.fontFamily": "CaskaydiaCove NF",
    "window.titleBarStyle": "custom",

    // win-dotfiles:theme:start
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#282A36",
        "titleBar.activeForeground": "#F8F8F2",
        "titleBar.inactiveBackground": "#282A36",
        "titleBar.inactiveForeground": "#6272A4",
        "titleBar.border": "#44475A",
        "activityBar.background": "#282A36",
        "activityBar.foreground": "#BD93F9",
        "activityBar.inactiveForeground": "#6272A4",
        "activityBar.activeBorder": "#BD93F9",
        "activityBarBadge.background": "#BD93F9",
        "activityBarBadge.foreground": "#282A36",
        "sideBar.background": "#282A36",
        "sideBar.foreground": "#6272A4",
        "sideBarTitle.foreground": "#F8F8F2",
        "sideBarSectionHeader.background": "#44475A",
        "sideBarSectionHeader.foreground": "#F8F8F2",
        "statusBar.background": "#282A36",
        "statusBar.foreground": "#6272A4",
        "statusBar.noFolderBackground": "#282A36",
        "statusBar.debuggingBackground": "#BD93F9",
        "statusBar.debuggingForeground": "#282A36",
        "editor.background": "#282A36",
        "editorGroupHeader.tabsBackground": "#282A36",
        "tab.activeBackground": "#44475A",
        "tab.inactiveBackground": "#282A36",
        "tab.activeForeground": "#F8F8F2",
        "tab.inactiveForeground": "#6272A4",
        "tab.activeBorderTop": "#BD93F9",
        "tab.border": "#282A36",
        "panel.background": "#282A36",
        "panelTitle.activeForeground": "#F8F8F2",
        "button.background": "#BD93F9",
        "button.foreground": "#282A36",
        "button.hoverBackground": "#8BE9FD",
        "focusBorder": "#BD93F9",
        "list.activeSelectionBackground": "#44475A",
        "list.activeSelectionForeground": "#F8F8F2",
        "list.hoverBackground": "#44475A",
        "badge.background": "#BD93F9",
        "badge.foreground": "#282A36",
        "terminal.background": "#282A36",
        "terminal.foreground": "#F8F8F2"
    }
    // win-dotfiles:theme:end
}
